---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
import { site } from '../data/site';

const success = Astro.url.searchParams.get('success') === 'true';
---

<Base title="Inquire Now" current="/contact" description="Reach out to Milestones by Gloria — let's plan your milestone together.">
  <Section bg="cream">
    <div class="container-narrow">
      <div class="text-center">
        <p class="eyebrow">Get In Touch</p>
        <h1 class="h1 mt-3">Contact Me</h1>
        <p class="lead mt-5" style="font-family:var(--font-serif);font-style:italic;color:var(--color-brown);">
          Whether it's a question, a kind word, or a collaboration idea — I'd love to hear from you.
        </p>
      </div>

      {success ? (
        <div class="success-card">
          <h2 class="serif-h" style="font-size:1.75rem;font-style:italic;">Thank you!</h2>
          <p class="mt-3">Your message has landed safely. I'll be in touch shortly.</p>
          <a href="/" class="btn btn-ghost mt-6">Return Home</a>
        </div>
      ) : (
        <form
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          action="/contact?success=true"
          class="contact-form mt-8"
        >
          {/* Required hidden inputs for Netlify */}
          <input type="hidden" name="form-name" value="contact" />
          <p class="hp"><label>Don't fill this out: <input name="bot-field" /></label></p>

          <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" required autocomplete="name" />
          </div>

          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required autocomplete="email" />
          </div>

          <div class="form-group">
            <label for="message">Your Message</label>
            <textarea id="message" name="message" required rows="6"></textarea>
          </div>

          <button type="submit" class="btn btn-dark form-submit">Send Message</button>
        </form>
      )}

      <div class="alt-contact mt-8">
        <p class="eyebrow text-center">Other Ways to Reach Me</p>
        <div class="alt-grid mt-5">
          <a href={site.emailHref} class="alt-tile">
            <p class="alt-label">Email</p>
            <p class="alt-value">{site.email}</p>
          </a>
          {site.socials.instagram && (
            <a href={site.socials.instagram} target="_blank" rel="noopener" class="alt-tile">
              <p class="alt-label">Instagram</p>
              <p class="alt-value">@milestonesbygloria</p>
            </a>
          )}
          {site.socials.facebook && (
            <a href={site.socials.facebook} target="_blank" rel="noopener" class="alt-tile">
              <p class="alt-label">Facebook</p>
              <p class="alt-value">Milestones by Gloria</p>
            </a>
          )}
        </div>
      </div>
    </div>
  </Section>
</Base>

<style>
  .contact-form {
    background: var(--color-white);
    padding: var(--sp-7);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-soft);
  }
  .form-submit { width: 100%; margin-top: var(--sp-3); }
  .hp { position: absolute; left: -9999px; }

  .success-card {
    text-align: center;
    background: var(--color-white);
    padding: var(--sp-8) var(--sp-7);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-soft);
    margin-top: var(--sp-8);
  }

  .alt-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-4);
  }
  .alt-tile {
    display: block;
    padding: var(--sp-5);
    background: var(--color-white);
    border-radius: var(--radius-md);
    text-align: center;
    transition: transform var(--transition), box-shadow var(--transition);
    box-shadow: var(--shadow-soft);
  }
  .alt-tile:hover { transform: translateY(-2px); box-shadow: var(--shadow-lift); }
  .alt-label {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-brown);
    margin-bottom: var(--sp-2);
  }
  .alt-value {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-brown);
    font-size: 0.95rem;
  }

  @media (max-width: 700px) {
    .contact-form { padding: var(--sp-5); }
    .alt-grid { grid-template-columns: 1fr; }
  }
</style>
