---
import Base from '../layouts/Base.astro';
import { site } from '../data/site';
---

<Base title={undefined} transparentNav={true} current="/" hideFooter={true} bodyClass="home-body">
  <section class="hero">
    <div class="hero-bg">
      <img src="/images/hero-wedding-party.jpg" alt="" fetchpriority="high" />
    </div>
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="hero-content">
      <h1 class="display">{site.name}</h1>
      <p class="hero-tagline">{site.tagline}</p>
      <div class="hero-ctas">
        <a href="/contact" class="btn btn-primary">Inquire Now</a>
        <a href="/services" class="btn btn-primary">View Services</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .home-body { background: #000; }
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    isolation: isolate;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -2;
  }
  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(180deg, rgba(0,0,0,0.40) 0%, rgba(0,0,0,0.25) 40%, rgba(0,0,0,0.55) 100%);
  }
  .hero-content {
    text-align: center;
    color: var(--color-white);
    padding: var(--sp-6) var(--sp-5);
    max-width: 1100px;
    width: 100%;
  }
  .hero-content .display {
    font-size: clamp(2.75rem, 9vw, 7.25rem);
    line-height: 1;
    color: var(--color-white);
    text-shadow: 0 4px 30px rgba(0,0,0,0.35);
  }
  .hero-tagline {
    margin-top: var(--sp-5);
    font-family: var(--font-sans);
    font-size: clamp(0.7rem, 1.2vw, 0.95rem);
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--color-white);
    font-weight: 500;
  }
  .hero-ctas {
    margin-top: var(--sp-7);
    display: flex;
    gap: var(--sp-4);
    justify-content: center;
    flex-wrap: wrap;
  }
  /* Home-only button override: dark navy for strong contrast on the hero photo */
  .hero-ctas .btn {
    background: var(--color-navy);
    color: var(--color-white);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.35);
  }
  .hero-ctas .btn:hover {
    background: var(--color-navy-deep);
    transform: translateY(-1px);
  }
  @media (max-width: 600px) {
    .hero-tagline { letter-spacing: 0.22em; line-height: 1.6; }
    .hero-ctas .btn { padding: 0.85rem 1.4rem; font-size: 0.7rem; }
  }
</style>
