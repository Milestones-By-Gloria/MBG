---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';

interface Benefit { number: string; title: string; body: string }

const benefits: Benefit[] = [
  {
    number: '01',
    title: 'A Stress-Free Experience',
    body:
      "From timelines to vendor communication, every detail is carefully managed so you don't have to carry the pressure. You get to be fully present, not worrying about what's happening behind the scenes.",
  },
  {
    number: '02',
    title: 'Calm, Reliable Coordination',
    body:
      'Events can be fast-paced and unpredictable. I bring a steady, organized presence that keeps everything running smoothly, no matter what comes up.',
  },
  {
    number: '03',
    title: 'Intentional & Personalized Planning',
    body:
      'Your event is not a template. Every detail is thoughtfully tailored to reflect your vision, your values, and your story.',
  },
  {
    number: '04',
    title: 'Attention to Every Detail',
    body:
      "It's the small details that elevate an event from good to unforgettable. From timing to flow to finishing touches, nothing is overlooked.",
  },
  {
    number: '05',
    title: 'A Partner You Can Trust',
    body:
      "You're not just hiring a coordinator. You're gaining someone who genuinely cares about your experience and your event. I treat every milestone with the same level of care and importance as if it were my own.",
  },
  {
    number: '06',
    title: 'Experience With Diverse Events',
    body:
      'From weddings and milestone celebrations to school functions and large community events, I bring adaptability, organization, and creativity to every setting.',
  },
];

const promises = [
  'You can relax and enjoy your event',
  'Your guests experience a smooth, well-organized celebration',
  'Every detail is handled with care',
  'Your vision is brought to life beautifully',
];
---

<Base title="Benefits" current="/benefits">

  <Section bg="cream">
    <div class="container">
      <div class="hero-row">
        <div class="left">
          <h1 class="h1">Why Milestones<br/>by Gloria</h1>
        </div>
        <div class="right">
          <p class="serif-h" style="font-size:1.35rem;line-height:1.4;font-style:italic;">
            More Than Event Planning: A Thoughtful, Stress-Free Experience
          </p>
          <p class="mt-5" style="color:var(--color-ink-soft);">
            Planning an event is more than organizing details. It's about creating a moment that feels meaningful, seamless, and truly unforgettable.
          </p>
          <p class="mt-3" style="color:var(--color-ink-soft);">
            At Milestones by Gloria, I bring a calm, intentional, and detail-driven approach to every event, so you can focus on what matters most.
          </p>
        </div>
      </div>

      <div class="benefit-grid mt-8">
        {benefits.map((b, idx) => (
          <article class:list={['benefit', { right: idx % 2 === 1 }]}>
            <p class="num">{b.number}</p>
            <h2 class="b-title">{b.title}</h2>
            <p class="b-body">{b.body}</p>
          </article>
        ))}
      </div>
    </div>
  </Section>

  <Section bg="periwinkle">
    <div class="container-narrow text-center">
      <h2 class="serif-h" style="font-size:1.6rem;letter-spacing:0.06em;">WHAT THIS MEANS FOR YOU?</h2>
      <ul class="promises mt-6">
        {promises.map((p) => <li>{p}</li>)}
      </ul>
      <p class="closing mt-7">
        Your milestone deserves more than just coordination; it deserves intention, care, and someone who truly understands the importance of the moment.
      </p>
      <div class="cta-pair mt-7">
        <a href="/contact" class="btn btn-dark">Inquire Now</a>
        <a href="/services" class="btn btn-ghost">Services &amp; Packages</a>
      </div>
    </div>
  </Section>
</Base>

<style>
  .hero-row {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: var(--sp-7);
    align-items: start;
  }
  .hero-row .h1 { line-height: 1.1; }
  @media (max-width: 800px) {
    .hero-row { grid-template-columns: 1fr; }
  }

  .benefit-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-7) var(--sp-8);
  }
  .benefit { padding-top: var(--sp-3); border-top: 1px solid var(--color-border); }
  .benefit.right { /* visual offset for the right column to feel like alternating layout */ }
  .num {
    font-family: var(--font-display);
    font-size: 2.25rem;
    color: var(--color-brown);
    line-height: 1;
    margin-bottom: var(--sp-3);
  }
  .b-title {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1.05rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-brown);
    margin-bottom: var(--sp-3);
  }
  .b-body { color: var(--color-ink-soft); }

  @media (max-width: 800px) {
    .benefit-grid { grid-template-columns: 1fr; }
  }

  .promises {
    display: inline-flex;
    flex-direction: column;
    gap: var(--sp-3);
    text-align: left;
  }
  .promises li {
    font-family: var(--font-sans);
    color: var(--color-brown);
    font-size: 1.05rem;
    padding-left: 1.6rem;
    position: relative;
  }
  .promises li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.7rem;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-brown);
  }
  .closing {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-brown);
    font-size: 1.2rem;
    line-height: 1.5;
  }
</style>
