---
import { nav, site } from '../data/site';

interface Props {
  transparent?: boolean;
  current?: string;
}

const { transparent = false, current = '' } = Astro.props;
---

<header class:list={['site-nav', { 'is-transparent': transparent }]}>
  <div class="container-wide nav-inner">
    <a href="/" class="brand" aria-label={site.name}>{site.name}</a>

    <button class="nav-toggle" aria-label="Open menu" aria-expanded="false" data-nav-toggle>
      <span></span><span></span><span></span>
    </button>

    <nav class="nav-links" data-nav-links>
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={['nav-link', { active: item.href === current }]}
          aria-current={item.href === current ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
      <a href="/contact" class:list={['btn btn-dark nav-cta', { active: current === '/contact' }]}>Inquire Now</a>
    </nav>
  </div>
</header>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-cream);
    border-bottom: 1px solid var(--color-border);
    transition: background 250ms ease, box-shadow 250ms ease;
  }
  .site-nav.is-transparent {
    position: fixed;
    width: 100%;
    background: transparent;
    border-bottom-color: transparent;
  }
  .site-nav.is-transparent.scrolled {
    background: rgba(251, 247, 247, 0.92);
    backdrop-filter: blur(8px);
    border-bottom-color: var(--color-border);
  }
  .nav-inner {
    height: var(--nav-height);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-5);
  }
  .brand {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-brown);
    line-height: 1;
    letter-spacing: 0.01em;
  }
  .site-nav.is-transparent:not(.scrolled) .brand,
  .site-nav.is-transparent:not(.scrolled) .nav-link {
    color: var(--color-white);
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--sp-6);
  }
  .nav-link {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-brown);
    padding: 0.5rem 0;
    position: relative;
    transition: opacity var(--transition);
  }
  .nav-link:hover { opacity: 0.7; }
  .nav-link.active::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 1px;
    background: currentColor;
  }
  .nav-cta { padding: 0.65rem 1.25rem; font-size: 0.72rem; }
  /* Home-only: nav Inquire Now button matches the hero CTAs (soft periwinkle) */
  .site-nav.is-transparent .nav-cta {
    background: #f4f6fc;
    color: var(--color-black);
  }
  .site-nav.is-transparent .nav-cta:hover {
    background: #e6eaf5;
  }

  .nav-toggle {
    display: none;
    background: none;
    border: 0;
    width: 36px;
    height: 36px;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    cursor: pointer;
    padding: 0;
  }
  .nav-toggle span {
    display: block;
    height: 2px;
    background: var(--color-brown);
    transition: transform var(--transition), opacity var(--transition);
  }
  .site-nav.is-transparent:not(.scrolled) .nav-toggle span { background: var(--color-white); }

  @media (max-width: 900px) {
    .nav-toggle { display: flex; }
    .nav-links {
      position: absolute;
      top: var(--nav-height);
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: flex-start;
      gap: var(--sp-3);
      padding: var(--sp-5) var(--sp-5) var(--sp-6);
      background: var(--color-cream);
      border-bottom: 1px solid var(--color-border);
      transform: translateY(-12px);
      opacity: 0;
      pointer-events: none;
      transition: transform var(--transition), opacity var(--transition);
    }
    .nav-links.open {
      transform: translateY(0);
      opacity: 1;
      pointer-events: auto;
    }
    .nav-link, .nav-cta { width: 100%; }
    .nav-cta { justify-content: flex-start; padding: 0.85rem 1.25rem; }
    /* The mobile dropdown always has a cream background. Force readable
       link colours even when the parent nav is in transparent mode —
       otherwise on the home page the links inherit white from the
       `.is-transparent:not(.scrolled)` rule and the menu looks like an
       empty white box until a scroll triggers a colour change. */
    .site-nav.is-transparent:not(.scrolled) .nav-links .nav-link {
      color: var(--color-brown);
    }
  }
</style>

<script>
  // Mobile nav toggle + transparent-on-scroll handling
  const nav = document.querySelector('.site-nav');
  const toggle = document.querySelector('[data-nav-toggle]') as HTMLButtonElement | null;
  const links = document.querySelector('[data-nav-links]') as HTMLElement | null;

  if (toggle && links) {
    toggle.addEventListener('click', () => {
      const isOpen = links.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(isOpen));
    });
    links.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => {
        links.classList.remove('open');
        toggle.setAttribute('aria-expanded', 'false');
      })
    );
  }

  if (nav?.classList.contains('is-transparent')) {
    const onScroll = () => {
      if (window.scrollY > 24) nav.classList.add('scrolled');
      else nav.classList.remove('scrolled');
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
