---
import { site, nav } from '../data/site';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container-wide footer-inner">
    <div class="footer-brand">
      <p class="brand-mark">{site.name}</p>
      <p class="brand-line">{site.tagline}</p>
    </div>

    <nav class="footer-links" aria-label="Footer">
      {nav.map((item) => <a href={item.href}>{item.label}</a>)}
      <a href="/contact">Inquire</a>
    </nav>

    <div class="footer-meta">
      <a href={site.emailHref} class="footer-email">{site.email}</a>
      <ul class="footer-socials">
        {site.socials.instagram && (
          <li><a href={site.socials.instagram} target="_blank" rel="noopener" aria-label="Instagram">Instagram</a></li>
        )}
        {site.socials.facebook && (
          <li><a href={site.socials.facebook} target="_blank" rel="noopener" aria-label="Facebook">Facebook</a></li>
        )}
      </ul>
    </div>
  </div>
  <div class="container-wide footer-bottom">
    <p>© {year} {site.name}. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-cream);
    border-top: 1px solid var(--color-border);
    padding: var(--sp-8) 0 var(--sp-5);
    color: var(--color-brown);
    font-size: var(--fs-body-sm);
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: var(--sp-7);
    align-items: start;
  }
  .footer-brand .brand-mark {
    font-family: var(--font-display);
    font-size: 1.6rem;
    line-height: 1.1;
    color: var(--color-brown);
  }
  .footer-brand .brand-line {
    margin-top: var(--sp-3);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-size: 0.7rem;
    opacity: 0.8;
  }
  .footer-links {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .footer-links a {
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-size: 0.75rem;
    transition: opacity var(--transition);
  }
  .footer-links a:hover { opacity: 0.7; }
  .footer-meta { display: flex; flex-direction: column; gap: var(--sp-3); }
  .footer-email {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1rem;
  }
  .footer-socials {
    display: flex;
    gap: var(--sp-4);
    flex-wrap: wrap;
  }
  .footer-socials a {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    transition: opacity var(--transition);
  }
  .footer-socials a:hover { opacity: 0.7; }
  .footer-bottom {
    margin-top: var(--sp-7);
    padding-top: var(--sp-5);
    border-top: 1px solid var(--color-border);
    text-align: center;
    font-size: 0.75rem;
    opacity: 0.7;
  }
  @media (max-width: 800px) {
    .footer-inner { grid-template-columns: 1fr; gap: var(--sp-5); }
  }
</style>
