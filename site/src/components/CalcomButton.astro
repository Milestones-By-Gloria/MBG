---
import { site } from '../data/site';

interface Props {
  label?: string;
  variant?: 'primary' | 'dark' | 'ghost';
}
const { label = 'Book Free Consultation', variant = 'dark' } = Astro.props;
---

<button
  type="button"
  class={`btn btn-${variant}`}
  data-cal-link={site.calcomLink}
  data-cal-namespace="consultation"
  data-cal-config='{"layout":"month_view"}'
>
  {label}
</button>

<script>
  // Cal.com embed bootstrap — runs once per page even if there are multiple
  // CalcomButton instances. Uses the official Cal.com snippet with a named
  // namespace, then lets Cal.com attach click handlers automatically based
  // on the [data-cal-link][data-cal-namespace] attributes on each button.
  // @ts-ignore
  if (!window.__calBootstrapped) {
    // @ts-ignore
    window.__calBootstrapped = true;

    // Official Cal.com embed snippet
    // @ts-ignore
    (function (C, A, L) {
      let p = function (a: any, ar: any) { a.q.push(ar); };
      // @ts-ignore
      let d = C.document;
      // @ts-ignore
      C.Cal = C.Cal || function () {
        // @ts-ignore
        let cal = C.Cal;
        let ar = arguments;
        if (!cal.loaded) {
          cal.ns = {};
          cal.q = cal.q || [];
          d.head.appendChild(d.createElement('script')).src = A;
          cal.loaded = true;
        }
        if (ar[0] === L) {
          const api = function () { p(api, arguments); };
          const ns = ar[1];
          api.q = api.q || [];
          if (typeof ns === 'string') {
            cal.ns[ns] = cal.ns[ns] || api;
            p(cal.ns[ns], ar);
            p(cal, ['initNamespace', ns]);
          } else p(cal, ar);
          return;
        }
        p(cal, ar);
      };
    })(window, 'https://app.cal.com/embed/embed.js', 'init');

    // @ts-ignore
    window.Cal('init', 'consultation', { origin: 'https://cal.com' });
    // @ts-ignore
    window.Cal.ns.consultation('ui', {
      styles: { branding: { brandColor: '#334C6B' } },
      hideEventTypeDetails: false,
      layout: 'month_view',
    });
  }
</script>
